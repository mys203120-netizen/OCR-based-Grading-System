APP_ENV=local
DATABASE_URL=postgresql+asyncpg://ctd_ocr:ctd_ocr@localhost:5432/ctd_ocr

# gemini: real Gemini calls, mock: local deterministic responses for wiring tests.
AI_PROVIDER=gemini
GEMINI_API_KEY="API 키를 입력하세요."
GEMINI_OCR_MODEL=gemini-3.5-flash
GEMINI_GRADING_MODEL=gemini-3.5-flash

QUEUE_PROVIDER=redis
REDIS_URL=redis://localhost:6379/0
GRADING_QUEUE_NAME=ctd-grading-jobs
GRADING_JOB_TIMEOUT_SECONDS=1800
GRADING_JOB_RESULT_TTL_SECONDS=86400
GRADING_JOB_FAILURE_TTL_SECONDS=604800

MESSAGE_PROVIDER=solapi_kakao
SOLAPI_BASE_URL=https://api.solapi.com
SOLAPI_API_KEY="API 키를 입력하세요."
SOLAPI_API_SECRET="API 시크릿을 입력하세요."
SOLAPI_SENDER_NUMBER="발신번호를 입력하세요."
SOLAPI_KAKAO_PF_ID="카카오 채널 PF ID를 입력하세요."
SOLAPI_KAKAO_TEMPLATE_ID="알림톡 템플릿 ID를 입력하세요."
SOLAPI_KAKAO_BODY_VARIABLE="#{내용}"
SOLAPI_DISABLE_SMS_FALLBACK=false
SOLAPI_TIMEOUT_SECONDS=10

OCR_CONCURRENCY=4
GRADING_CONCURRENCY=4
RENDER_DPI=220
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://www.ctdenglish.com"]
